# Las VITE_SUPABASE_* las usa el cliente (todos los trabajadores), viajan en
# el bundle público a propósito -- ver SEGURIDAD_PENDIENTE.md.
VITE_SUPABASE_URL=https://TU-PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=TU-CLAVE-ANON-PUBLICA
# Sin prefijo VITE_ = server-only: sólo la función serverless /api/entrar-admin
# la ve, ya no viaja en el JavaScript del navegador.
ADMIN_CLAVE=cambia-esta-clave
